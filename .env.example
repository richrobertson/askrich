# Ask Rich environment template
# Local development may use Chroma persistence while production targets
# Cloudflare-native services (Vectorize, D1, optional R2).
#
# Default: OpenAI API for LLM and embeddings.
# https://platform.openai.com/account/api-keys
# Get your API key and set LLM_API_KEY and EMBEDDING_API_KEY below.

LLM_PROVIDER=openai
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o

EMBEDDING_PROVIDER=openai
EMBEDDING_API_BASE=https://api.openai.com/v1
EMBEDDING_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

LANGSMITH_API_KEY=
# Set to 'true' to enable LangSmith tracing (may send prompts/content to a third-party service).
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=ask-rich

VECTOR_STORE_PROVIDER=vectorize
VECTORIZE_INDEX=
D1_DATABASE_ID=
R2_BUCKET_NAME=

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

CHROMA_PERSIST_DIRECTORY=
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000
