# Ask Rich environment template
# Local development may use Chroma persistence while production targets
# Cloudflare-native services (Vectorize, D1, optional R2).
#
# Fill in the provider and credentials for your chosen LLM and embedding service.
# Supported LLM_PROVIDER values: openai, openai-compatible, together, groq, ollama
# Leave LLM_PROVIDER and EMBEDDING_PROVIDER blank to use local extractive/hash fallbacks.
#
# Example — OpenAI:
#   LLM_PROVIDER=openai
#   LLM_API_BASE=https://api.openai.com/v1
#   LLM_MODEL=gpt-4o
#
# Example — Ollama (local, no key required):
#   LLM_PROVIDER=ollama
#   LLM_API_BASE=http://localhost:11434/v1
#   LLM_MODEL=llama3

LLM_PROVIDER=
LLM_API_BASE=
LLM_API_KEY=your-llm-provider-api-key
LLM_MODEL=

EMBEDDING_PROVIDER=
EMBEDDING_API_BASE=
EMBEDDING_API_KEY=your-embedding-provider-api-key
EMBEDDING_MODEL=
EMBEDDING_DIMENSION=1536

LANGSMITH_API_KEY=
# Set to 'true' to enable LangSmith tracing (may send prompts/content to a third-party service).
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=ask-rich

VECTOR_STORE_PROVIDER=vectorize
VECTORIZE_INDEX=
D1_DATABASE_ID=
R2_BUCKET_NAME=

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

CHROMA_PERSIST_DIRECTORY=
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000
