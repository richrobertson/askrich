# Ask Rich environment template
# Local development may use Chroma persistence while production targets
# Cloudflare-native services (Vectorize, D1, optional R2).
#
# Default: Ollama running locally with Llama 3.2 + nomic-embed-text.
# Start Ollama and pull models before running:
#   ollama pull llama3.2
#   ollama pull nomic-embed-text

LLM_PROVIDER=ollama
LLM_API_BASE=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3.2

EMBEDDING_PROVIDER=ollama
EMBEDDING_API_BASE=http://localhost:11434/v1
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768

LANGSMITH_API_KEY=
# Set to 'true' to enable LangSmith tracing (may send prompts/content to a third-party service).
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=ask-rich

VECTOR_STORE_PROVIDER=vectorize
VECTORIZE_INDEX=
D1_DATABASE_ID=
R2_BUCKET_NAME=

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

CHROMA_PERSIST_DIRECTORY=
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000,http://127.0.0.1:8000
